ANTHROPIC_API_KEY=sk-ant-replace_me
OPENAI_API_KEY=sk-replace_me

# Google OAuth — preferred path (works in Lambda; no file mount).
# Get these by running scripts/auth.py once locally and copying values out
# of the resulting token.json + your OAuth client config.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional fallback for local dev only — used only if the three env vars
# above are empty. Lambda deploys ignore this.
GOOGLE_CREDENTIALS_PATH=token.json

USER_TIMEZONE=Europe/London
CORS_ORIGINS=http://localhost:5173
MOCK_PROVIDERS=false
# Only enables deterministic echo when MOCK_PROVIDERS=true (see use_deterministic_llm_echo).
MOCK_LLM=false

# API guardrails (0 = rate limit off)
# MAX_USER_MESSAGE_CHARS=12000
# RATE_LIMIT_MAX_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60
# MAX_AGENT_TURNS=6
# MAX_VOICE_AUDIO_BYTES=4194304
# ABUSE_GUARDS_ENABLED=true
# ABUSE_OFF_TOPIC_GUARDS=true
# LLM intent classifier (gpt-4o-mini) for messages with no strong calendar-keywords; off in tests
# INTENT_CLASSIFIER_ENABLED=true
# INTENT_CLASSIFIER_MODEL=gpt-4o-mini
# Session compaction (summarize older history when over ~60% of budget)
# SESSION_COMPACTION_ENABLED=true
# COMPACTION_CONTEXT_BUDGET_TOKENS=100000
# COMPACTION_THRESHOLD=0.6
# COMPACTION_KEEP_LAST_ITEMS=8
# COMPACTION_SUMMARY_MODEL=gpt-4o-mini

# Clerk (optional) — when enabled, the API requires Authorization: Bearer <Clerk session JWT>
# (same Clerk application as the frontend’s VITE_CLERK_PUBLISHABLE_KEY).
#
# Step 1: Frontend only — get the Publishable key in Clerk dashboard → your app.
#
# Step 2: Backend "issuer" and "JWKS" (same host; two env vars)
#  • In Clerk: open your application → Configure → Developers (or API keys in older UIs).
#  • Find "Frontend API" (or Instance / Clerk domain) — a URL like https://<name>.clerk.accounts.com
#    with no path on the end.
#  • Set CLERK_ISSUER to that URL exactly, e.g. https://cute-liger-12.clerk.accounts.com
#  • Set CLERK_JWKS_URL to the SAME host with this path: /.well-known/jwks.json
#    example: https://cute-liger-12.clerk.accounts.com/.well-known/jwks.json
#  (You are not “finding iss inside a token”—the Frontend API URL is the iss Clerk uses.)
#
# CLERK_ENABLED=false
# CLERK_ISSUER=https://your-frontend-api-host.clerk.accounts.com
# CLERK_JWKS_URL=https://your-frontend-api-host.clerk.accounts.com/.well-known/jwks.json
