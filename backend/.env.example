ANTHROPIC_API_KEY=sk-ant-replace_me
OPENAI_API_KEY=sk-replace_me

# Google OAuth — preferred path (works in Lambda; no file mount).
# Get these by running scripts/auth.py once locally and copying values out
# of the resulting token.json + your OAuth client config.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional fallback for local dev only — used only if the three env vars
# above are empty. Lambda deploys ignore this.
GOOGLE_CREDENTIALS_PATH=token.json

USER_TIMEZONE=Europe/London
CORS_ORIGINS=http://localhost:5173
MOCK_PROVIDERS=false
# Only enables deterministic echo when MOCK_PROVIDERS=true (see use_deterministic_llm_echo).
MOCK_LLM=false

# API guardrails (0 = rate limit off)
# MAX_USER_MESSAGE_CHARS=12000
# RATE_LIMIT_MAX_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60
# MAX_AGENT_TURNS=6
# MAX_VOICE_AUDIO_BYTES=4194304
# ABUSE_GUARDS_ENABLED=true
